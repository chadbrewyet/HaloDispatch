name = "halo-dispatch-api"
main = "worker/halo-proxy.js"
compatibility_date = "2026-05-18"

# Set these as encrypted Cloudflare Worker secrets:
# wrangler secret put HALO_CLIENT_ID
# wrangler secret put HALO_CLIENT_SECRET

[vars]
# Copy these values from HaloPSA > Configuration > Integrations > HaloPSA API > API Details.
HALO_AUTH_URL = "https://gagepsa.halopsa.com/auth/token"
HALO_RESOURCE_SERVER = "https://gagepsa.halopsa.com"
HALO_SCOPE = "all"

# Replace these sample IDs with real Halo agent IDs.
TECHNICIAN_MAP_JSON = "{\"davis\":123,\"mlee\":456,\"aperez\":789,\"jkim\":101}"

# Required for dragging to the date-only / without-time section.
HALO_DISPATCH_DATE_FIELD_ID = "0"

# Optional. Leave blank or remove if Halo should use its default appointment type.
HALO_APPOINTMENT_TYPE_ID = ""
