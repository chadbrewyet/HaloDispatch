name = "halo-dispatch-api"
main = "worker/halo-proxy.js"
compatibility_date = "2026-05-18"

# Set these as encrypted Cloudflare Worker secrets:
# wrangler secret put HALO_CLIENT_ID
# wrangler secret put HALO_CLIENT_SECRET

[vars]
# Copy these values from HaloPSA > Configuration > Integrations > HaloPSA API > API Details.
HALO_AUTH_URL = "https://gagepsa.halopsa.com/auth/token"
HALO_RESOURCE_SERVER = "https://gagepsa.halopsa.com"
HALO_SCOPE = "all"
HALO_DISPLAY_TIME_ZONE = "America/Chicago"

# Optional legacy agent map. Numeric dashboard IDs are sent directly to Halo.
TECHNICIAN_MAP_JSON = "{}"

# Required for dragging to the date-only / without-time section.
HALO_DISPATCH_DATE_FIELD_ID = "486"
HALO_DISPATCH_DATE_FIELD_NAME = "CFTaskWithoutTimeDate"

# Optional. Leave blank or remove if Halo should use its default appointment type.
HALO_APPOINTMENT_TYPE_ID = ""

# Optional pagination controls. Halo Tickets documents page_size maximum 100.
HALO_PAGE_SIZE = "100"
HALO_MAX_PAGES = "50"

# Halo custom table storage for dispatch preferences and shared saved filters.
HALO_USER_PREF_TABLE_ID = "1013"
HALO_SAVED_FILTER_TABLE_ID = "1014"

# Optional custom table column names. Update these if your Halo columns use different database names.
HALO_PREF_AGENT_FIELD = "agent_id"
HALO_PREF_JSON_FIELD = "preferences_json"
HALO_FILTER_NAME_FIELD = "filter_name"
HALO_FILTER_TITLE_FIELD = "list_title"
HALO_FILTER_COLOR_FIELD = "color"
HALO_FILTER_JSON_FIELD = "filter_json"
HALO_FILTER_DELETED_FIELD = "deleted"
HALO_FILTER_UPDATED_BY_FIELD = "updated_by_agent_id"
HALO_STORAGE_UPDATED_AT_FIELD = "updated_at"
