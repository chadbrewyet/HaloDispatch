name = "halo-dispatch-api"
main = "worker/halo-proxy.js"
compatibility_date = "2026-05-18"

# Set these as encrypted Cloudflare Worker secrets:
# wrangler secret put HALO_CLIENT_ID
# wrangler secret put HALO_CLIENT_SECRET

[vars]
# Copy these values from HaloPSA > Configuration > Integrations > HaloPSA API > API Details.
HALO_AUTH_URL = "https://gagepsa.halopsa.com/auth/token"
HALO_RESOURCE_SERVER = "https://gagepsa.halopsa.com"
HALO_SCOPE = "all"
HALO_DISPLAY_TIME_ZONE = "America/Chicago"

# Optional legacy agent map. Numeric dashboard IDs are sent directly to Halo.
TECHNICIAN_MAP_JSON = "{}"

# Required for dragging to the date-only / without-time section.
HALO_DISPATCH_DATE_FIELD_ID = "486"
HALO_DISPATCH_DATE_FIELD_NAME = "CFTaskWithoutTimeDate"

# Optional. Leave blank or remove if Halo should use its default appointment type.
HALO_APPOINTMENT_TYPE_ID = ""

# Optional pagination controls. Halo Tickets documents page_size maximum 100.
HALO_PAGE_SIZE = "100"
HALO_MAX_PAGES = "50"

# Halo custom table storage for dispatch preferences and shared saved filters.
HALO_USER_PREF_TABLE_ID = "1013"
HALO_SAVED_FILTER_TABLE_ID = "1014"

# Optional custom table column names. Update these if your Halo columns use different database names.
HALO_PREF_AGENT_FIELD = "CFDispatchAgentID"
HALO_PREF_THEME_FIELD = "CFDispatchTheme"
HALO_PREF_ORIENTATION_FIELD = "CFDispatchOrientation"
HALO_PREF_SELECTED_TEAMS_FIELD = "CFDispatchSelectedTeams"
HALO_PREF_SELECTED_AGENTS_FIELD = "CFDispatchSelectedAgents"
HALO_PREF_PANEL_PINNED_FIELD = "CFDispatchPanelPinned"
HALO_PREF_PANEL_WIDTH_FIELD = "CFDispatchPanelWidth"
HALO_PREF_CALENDAR_START_FIELD = "CFDispatchCalendarStartTime"
HALO_PREF_CALENDAR_END_FIELD = "CFDispatchCalendarEndTime"
HALO_PREF_TECH_THEMES_FIELD = "CFDispatchTechThemes"
HALO_PREF_VISIBLE_TICKETS_FIELD = "CFDispatchVisibleTickets"
HALO_FILTER_NAME_FIELD = "CFDispatchFilterName"
HALO_FILTER_TITLE_FIELD = "CFDispatchFilterTitle"
HALO_FILTER_COLOR_FIELD = "CFDispatchFilterColor"
HALO_FILTER_CONDITIONS_FIELD = "CFDispatchFilterConditions"
HALO_FILTER_CREATED_BY_FIELD = "CFDispatchFilterCreatedBy"
HALO_FILTER_UPDATED_BY_FIELD = "CFDispatchFilterUpdatedBy"
HALO_FILTER_ACTIVE_FIELD = "CFDispatchFilterActive"
HALO_FILTER_CREATED_AT_FIELD = "CFDispatchFilterCreatedAt"
HALO_STORAGE_CREATED_AT_FIELD = "CFDispatchCreatedAt"
HALO_STORAGE_UPDATED_AT_FIELD = "CFDispatchUpdatedAt"
